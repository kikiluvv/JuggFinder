# JuggFinder — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- AI API Keys (required) ---
GEMINI_API_KEY=
GROQ_API_KEY=

# --- AI Models (override when vendors deprecate) ---
# Gemini 2.0 Flash is the current fast / cheap default.
GEMINI_MODEL=gemini-2.0-flash
# Groq's current Llama 3.3 is free-tier-friendly and more capable than 3.1-8b.
GROQ_MODEL=llama-3.3-70b-versatile

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./leads.db

# --- Scheduler ---
# Daily scrape time in HH:MM format (24-hour, local time)
SCRAPE_SCHEDULE_TIME=03:00

# --- Scraper tuning ---
# Geographic anchor for Google Maps queries.
SCRAPE_LOCATION=Boise Idaho
# Max listings per category per run (1-500).
SCRAPE_MAX_RESULTS=60
# Set to false to launch a visible Chromium window for debugging.
SCRAPE_HEADLESS=true
# Optional user-agent override. Leave blank to rotate a curated pool.
SCRAPE_USER_AGENT=

# --- Logging ---
LOG_LEVEL=INFO

# --- Outreach auto-send (Phase 16) ---
# Safety gate: keep false unless you've configured SMTP and want live sending.
OUTREACH_SEND_ENABLED=false
OUTREACH_SENDER_NAME=Boise Web Studio
OUTREACH_SENDER_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- Dev-only pipeline dry-run (Phase 17.2) ---
# When true, mounts POST /dev/pipeline-dry-run — seeds TEST BUSINESS, optional AI draft,
# simulated outreach + inbound on the timeline (no SMTP, no outreach_send_logs for sim send).
# Never enable on a public server.
DEV_PIPELINE_DRY_RUN_ENABLED=false
# Optional overrides for the seeded test lead:
# DEV_PIPELINE_TEST_BUSINESS_NAME=TEST BUSINESS
# DEV_PIPELINE_TEST_EMAIL=1kikiluvv@gmail.com
